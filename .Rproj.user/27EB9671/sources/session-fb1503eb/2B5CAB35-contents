test_that("clean_lst_data supprime les valeurs aberrantes", {
  lst <- simulate_raster_data(type = "lst", n_dates = 1)

  # Ajouter des valeurs aberrantes manuellement
  vals <- terra::values(lst)
  vals[1:5] <- 100  # > max_temp
  vals[6:10] <- -50 # < min_temp
  terra::values(lst) <- vals

  lst_clean <- clean_lst_data(lst, min_temp = 0, max_temp = 60, interpolate_na = FALSE)
  vals_clean <- terra::values(lst_clean)
  expect_true(all(is.na(vals_clean[1:5]) | vals_clean[1:5] <= 60, na.rm = TRUE))
})

test_that("calculate_lst_anomaly retourne meme dimensions", {
  lst <- simulate_raster_data(type = "lst", n_dates = 4)
  anom <- calculate_lst_anomaly(lst, method = "difference")

  expect_s4_class(anom, "SpatRaster")
  expect_equal(terra::nlyr(anom), terra::nlyr(lst))
  expect_equal(terra::ncol(anom), terra::ncol(lst))
  expect_equal(terra::nrow(anom), terra::nrow(lst))
})

test_that("calculate_lst_anomaly zscore a moyenne nulle", {
  lst <- simulate_raster_data(type = "lst", n_dates = 6)
  anom <- calculate_lst_anomaly(lst, method = "zscore")

  # La moyenne des z-scores devrait être proche de 0
  mean_pixel <- terra::global(anom[[1]], "mean", na.rm = TRUE)$mean
  expect_lt(abs(mean_pixel), 1.0)  # tolérance ample
})

