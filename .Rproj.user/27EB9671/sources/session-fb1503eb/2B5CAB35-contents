library(testthat)
library(microclimAg)

test_that("simulate_weather_data retourne un data.frame correct", {
  weather <- simulate_weather_data(n_days = 10, n_stations = 3)

  expect_s3_class(weather, "data.frame")
  expect_true(nrow(weather) == 30)  # 10 jours x 3 stations
  expect_true(all(c("date", "station_id", "temperature", "humidity",
                    "wind_speed", "radiation") %in% names(weather)))
  expect_true(all(!is.na(weather$temperature)))
  expect_true(all(weather$humidity >= 0 & weather$humidity <= 100))
  expect_true(all(weather$wind_speed >= 0))
})

test_that("simulate_raster_data retourne un SpatRaster valide", {
  lst <- simulate_raster_data(type = "lst", n_dates = 3)

  expect_s4_class(lst, "SpatRaster")
  expect_equal(terra::nlyr(lst), 3)
  expect_true(all(terra::values(lst) >= 20, na.rm = TRUE))
  expect_true(all(terra::values(lst) <= 55, na.rm = TRUE))
})

