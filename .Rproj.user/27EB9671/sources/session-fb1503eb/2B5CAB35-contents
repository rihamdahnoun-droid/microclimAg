test_that("cluster_thermal_zones produit k clusters", {
  lst    <- simulate_raster_data(type = "lst", n_dates = 1)
  result <- cluster_thermal_zones(lst, n_clusters = 3)

  expect_true(is.list(result))
  expect_true(all(c("raster", "stats", "labels") %in% names(result)))
  expect_s4_class(result$raster, "SpatRaster")
  expect_equal(nrow(result$stats), 3)

  unique_clusters <- unique(as.vector(terra::values(result$raster)))
  unique_clusters <- unique_clusters[!is.na(unique_clusters)]
  expect_true(all(unique_clusters %in% 1:3))
})

test_that("model_temperature_relationships retourne un modele lm", {
  lst     <- simulate_raster_data(type = "lst",  n_dates = 1)
  ndvi    <- simulate_raster_data(type = "ndvi", n_dates = 1)
  features <- extract_microclimate_features(lst, ndvi, n_sample = 200)

  model <- model_temperature_relationships(features)

  expect_true(is.list(model))
  expect_s3_class(model$model, "lm")
  expect_true(model$r_squared >= 0 & model$r_squared <= 1)
})

test_that("interpolate_temperature retourne un SpatRaster", {
  set.seed(42)
  stations_df <- data.frame(
    station_id  = paste0("ST", 1:8),
    longitude   = runif(8, -5.5, -5.0),
    latitude    = runif(8, 33.5, 34.0),
    temperature = runif(8, 25, 40)
  )
  stations_sf <- sf::st_as_sf(stations_df, coords = c("longitude", "latitude"), crs = 4326)
  temp_raster <- interpolate_temperature(stations_sf, method = "idw", resolution = 0.05)

  expect_s4_class(temp_raster, "SpatRaster")
  expect_true(all(terra::values(temp_raster) >= 20, na.rm = TRUE))
})

test_that("compare_lst_vs_ndvi retourne une correlation", {
  lst  <- simulate_raster_data(type = "lst",  n_dates = 1)
  ndvi <- simulate_raster_data(type = "ndvi", n_dates = 1)
  result <- compare_lst_vs_ndvi(lst, ndvi, plot = FALSE)

  expect_true(is.list(result))
  expect_true("correlation" %in% names(result))
  expect_true(result$correlation >= -1 & result$correlation <= 1)
})
