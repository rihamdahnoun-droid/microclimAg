test_that("extract_microclimate_features retourne un data.frame", {
  lst  <- simulate_raster_data(type = "lst",  n_dates = 1)
  ndvi <- simulate_raster_data(type = "ndvi", n_dates = 1)

  features <- extract_microclimate_features(lst, ndvi, n_sample = 100)

  expect_s3_class(features, "data.frame")
